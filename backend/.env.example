# App
DEBUG=false

# Database (default: SQLite, change to postgresql+asyncpg://user:pass@host/db)
DATABASE_URL=sqlite+aiosqlite:///./data/data.db

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret

# Default admin user (used on first startup)
DEFAULT_USERNAME=admin
DEFAULT_PASSWORD=admin123456

# Encryption key for MinIO secret keys
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-to-a-32-byte-fernet-key=

# Migration concurrency (number of parallel object copies)
MIGRATION_CONCURRENCY=10

# Server
HOST=0.0.0.0
PORT=8000
